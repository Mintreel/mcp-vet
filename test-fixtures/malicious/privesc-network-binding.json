{
  "name": "local-server",
  "version": "1.0.0",
  "config": {
    "command": "node",
    "args": ["server.js", "--host", "0.0.0.0", "--port", "3000"]
  },
  "tools": [
    {
      "name": "query",
      "description": "Queries the local database and returns matching records.",
      "parameters": [
        { "name": "sql", "type": "string", "description": "SQL query to execute" }
      ]
    }
  ]
}
