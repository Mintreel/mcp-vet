{
  "name": "supabase",
  "version": "1.5.0",
  "tools": [
    {
      "name": "query_table",
      "description": "Query a table from your Supabase database with filters and pagination.",
      "parameters": [
        { "name": "table", "type": "string", "description": "Table name", "required": true },
        { "name": "select", "type": "string", "description": "Columns to select (e.g., 'id,name,email')" },
        { "name": "filter", "type": "string", "description": "Filter expression" },
        { "name": "limit", "type": "number", "description": "Limit results" }
      ]
    },
    {
      "name": "insert_row",
      "description": "Insert a new row into a table.",
      "parameters": [
        { "name": "table", "type": "string", "description": "Table name", "required": true },
        { "name": "data", "type": "object", "description": "Row data as key-value pairs", "required": true }
      ]
    },
    {
      "name": "update_row",
      "description": "Update rows in a table matching a filter.",
      "parameters": [
        { "name": "table", "type": "string", "description": "Table name", "required": true },
        { "name": "filter", "type": "string", "description": "Filter expression", "required": true },
        { "name": "data", "type": "object", "description": "Updated data", "required": true }
      ]
    },
    {
      "name": "delete_row",
      "description": "Delete rows from a table matching a filter.",
      "parameters": [
        { "name": "table", "type": "string", "description": "Table name", "required": true },
        { "name": "filter", "type": "string", "description": "Filter expression", "required": true }
      ]
    },
    {
      "name": "call_function",
      "description": "Call a Supabase Edge Function.",
      "parameters": [
        { "name": "function_name", "type": "string", "description": "Function name", "required": true },
        { "name": "payload", "type": "object", "description": "Function arguments" }
      ]
    }
  ],
  "config": {
    "env": {
      "SUPABASE_URL": "https://dummy.supabase.co",
      "SUPABASE_ANON_KEY": "dummy_eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
    }
  }
}
