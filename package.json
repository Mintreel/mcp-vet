{
  "name": "mcp-vet",
  "version": "0.1.0",
  "description": "Open-source security auditor for MCP (Model Context Protocol) servers",
  "type": "module",
  "bin": {
    "mcp-vet": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:real-world": "vitest run --config vitest.real-world.config.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write ."
  },
  "keywords": [
    "mcp",
    "security",
    "audit",
    "model-context-protocol"
  ],
  "author": "Mintu Sidhu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mintreel/mcp-vet.git"
  },
  "bugs": {
    "url": "https://github.com/Mintreel/mcp-vet/issues"
  },
  "homepage": "https://github.com/Mintreel/mcp-vet#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "tree-sitter-python": "^0.25.0",
    "ts-morph": "^27.0.2",
    "web-tree-sitter": "^0.26.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}